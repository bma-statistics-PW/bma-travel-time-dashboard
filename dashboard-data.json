/* ════════════════════════════════════════════════════════════════════
   BMA Travel Time Dashboard — Stylesheet (v4 · Editorial + i18n + a11y)
   © Prapawadee_W.
   Editorial type system inspired by FT/WEF · BMA brand colors preserved
   ════════════════════════════════════════════════════════════════════ */

:root{
  /* ─── Brand palette (preserved) ─── */
  --primary-color:#0A2E5C;
  --secondary-color:#1F4E79;
  --accent-color:#D4AF37;
  --bg-light:#F4F7F9;
  --text-dark:#1a202c;
  --text-mid:#2C3E50;
  --text-muted:#647687;
  --status-red:#C0392B;
  --status-orange:#D35400;
  --status-green:#27AE60;
  --inner-color:#d63031;
  --middle-color:#e17055;
  --outer-color:#00b894;

  /* ─── Editorial type system ─── */
  --font-serif:'Noto Serif Display','IBM Plex Sans Thai','Sarabun',Georgia,serif;
  --font-sans:'IBM Plex Sans Thai','Sarabun',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  --font-mono:'IBM Plex Mono','SFMono-Regular',Consolas,Monaco,monospace;

  /* ─── Spacing ─── */
  --space-xs:.25rem;
  --space-sm:.5rem;
  --space-md:1rem;
  --space-lg:1.5rem;
  --space-xl:2rem;
  --space-2xl:3rem;

  /* ─── Type scale (PC default ≥1200px) ─── */
  --fs-display:36px;     /* hero h1 */
  --fs-h1:28px;          /* major section heading */
  --fs-h2:22px;          /* section heading */
  --fs-h3:18px;          /* subheading */
  --fs-lead:17px;        /* large body */
  --fs-body:16px;        /* body */
  --fs-small:14px;       /* small text */
  --fs-caption:12.5px;   /* meta/caption */
  --fs-eyebrow:11.5px;   /* uppercase eyebrow */

  --lh-display:1.2;
  --lh-heading:1.3;
  --lh-body:1.7;

  /* ─── Surfaces ─── */
  --bg:#fafbfc;
  --bg-canvas:#fff;
  --surface:#fff;
  --surface-2:#f8fafc;
  --surface-3:#f1f5f9;
  --border:#e2e8f0;
  --border-strong:#cbd5e1;

  --shadow-soft:0 1px 3px rgba(15,42,73,.06),0 1px 2px rgba(15,42,73,.04);
  --shadow-md:0 4px 12px rgba(15,42,73,.08),0 2px 4px rgba(15,42,73,.04);
  --shadow-lg:0 10px 30px rgba(15,42,73,.12),0 4px 8px rgba(15,42,73,.06);
  --radius-sm:6px;
  --radius-md:10px;
  --radius-lg:14px;
  --transition:cubic-bezier(.4,0,.2,1);

  /* a11y focus */
  --focus-ring:0 0 0 3px rgba(10,46,92,.35);
}

/* ─── Dark theme ─── */
:root[data-theme='dark']{
  --bg:#0f172a;
  --bg-canvas:#1e293b;
  --surface:#1e293b;
  --surface-2:#0f172a;
  --surface-3:#293548;
  --border:#334155;
  --border-strong:#475569;
  --text-dark:#f1f5f9;
  --text-mid:#cbd5e1;
  --text-muted:#94a3b8;
  --bg-light:#1e293b;
  --shadow-soft:0 1px 3px rgba(0,0,0,.4);
  --shadow-md:0 4px 12px rgba(0,0,0,.4);
  --shadow-lg:0 10px 30px rgba(0,0,0,.6);
}

*{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{
  font-family:var(--font-sans);
  font-size:var(--fs-body);
  line-height:var(--lh-body);
  color:var(--text-dark);
  background:linear-gradient(180deg,#E2E8F0 0%,#cbd5e1 100%);
  display:flex;flex-direction:column;align-items:center;
  min-height:100vh;
  font-feature-settings:'kern' 1,'liga' 1,'calt' 1;
  text-rendering:optimizeLegibility;
}
:root[data-theme='dark'] body{background:linear-gradient(180deg,#0f172a 0%,#0a1124 100%)}

/* ─── Typography rules ─── */
h1,h2,h3,h4{
  font-family:var(--font-serif);
  line-height:var(--lh-heading);
  letter-spacing:-.01em;
  color:var(--primary-color);
  font-weight:700;
}
:root[data-theme='dark'] h1,
:root[data-theme='dark'] h2,
:root[data-theme='dark'] h3,
:root[data-theme='dark'] h4{color:#f0c060}
h1{font-size:var(--fs-h1)}
h2{font-size:var(--fs-h2)}
h3{font-size:var(--fs-h3)}
p{font-size:var(--fs-body);line-height:var(--lh-body)}
small{font-size:var(--fs-small)}
a{color:#1d4ed8;transition:color .2s}
a:hover{color:#1e3a8a}
:root[data-theme='dark'] a{color:#93c5fd}
.tabular,
.font-mono,
[class*='-num'],
.kpi-speed,
.tomtom-value,
.scenario-kpi strong,
.zsm-val,
.card-stats span:last-child,
.card-value,
.modern-table td:not(:first-child),
.compare-table td,
.rt-table .speed-cell,
.rt-table .td-num,
table[data-zone-table] td:nth-child(3){
  font-family:var(--font-mono);
  font-variant-numeric:tabular-nums;
}

/* ─── Skip link (a11y) ─── */
.skip-link{
  position:absolute;left:0;top:0;
  background:var(--primary-color);color:#fff;
  padding:10px 16px;
  font-size:14px;font-weight:600;
  z-index:1000;
  transform:translateY(-100%);
  transition:transform .2s var(--transition);
}
.skip-link:focus{transform:translateY(0);outline:none}

.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

/* ─── Focus indicator ─── */
:focus-visible{outline:none;box-shadow:var(--focus-ring);border-radius:4px}

/* ─── Reveal animation ─── */
.reveal{opacity:0;transform:translateY(20px);transition:opacity .6s var(--transition),transform .6s var(--transition)}
.reveal.in-view{opacity:1;transform:translateY(0)}
@media (prefers-reduced-motion:reduce){
  .reveal{opacity:1;transform:none;transition:none}
  *,*::before,*::after{animation:none !important;transition:none !important}
}

/* ════════════════ Utility Bar ════════════════ */
.utility-bar{
  width:100%;
  background:#08203F;
  color:rgba(255,255,255,.85);
  font-size:13px;
  border-bottom:1px solid rgba(212,175,55,.18);
}
.utility-inner{
  max-width:1320px;margin:0 auto;
  padding:8px 24px;
  display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;
}
.utility-left{display:flex;gap:8px;align-items:center;font-family:var(--font-sans);letter-spacing:.02em}
.util-org{font-weight:600;color:#fff}
.util-sep{opacity:.4}
.util-dept{opacity:.85}
.utility-right{display:flex;gap:10px;align-items:center}
.util-btn{
  background:transparent;border:1px solid rgba(255,255,255,.2);
  color:rgba(255,255,255,.85);font-size:14px;
  width:34px;height:30px;border-radius:6px;cursor:pointer;
  display:inline-flex;align-items:center;justify-content:center;
  transition:.15s;
}
.util-btn:hover{background:rgba(255,255,255,.08);border-color:var(--accent-color);color:#f0c060}
.theme-icon{display:inline-block}
.lang-toggle{
  display:flex;background:rgba(255,255,255,.08);
  border-radius:6px;border:1px solid rgba(255,255,255,.15);
  padding:2px;
}
.lang-btn{
  background:transparent;border:none;color:rgba(255,255,255,.7);
  font-family:var(--font-sans);font-size:12.5px;font-weight:600;
  letter-spacing:.04em;
  padding:4px 12px;border-radius:4px;cursor:pointer;transition:.15s;
}
.lang-btn:hover{color:#fff}
.lang-btn.active{background:#f0c060;color:#08203F;font-weight:700}

/* ════════════════ A4 Canvas ════════════════ */
.a4-canvas{
  width:210mm;max-width:1320px;min-height:297mm;
  background:var(--bg-canvas);
  box-shadow:var(--shadow-lg);
  overflow:hidden;
  padding:0 0 40px;
  display:flex;flex-direction:column;gap:25px;
  border-radius:0 0 8px 8px;
  margin-bottom:20px;
}
.a4-body{padding:0 50px;display:flex;flex-direction:column;gap:28px}

/* ════════════════ Hero ════════════════ */
.report-hero{
  background:linear-gradient(135deg,#0b2545 0%,#1a4a7e 55%,#0e6b7a 100%);
  padding:52px 50px 46px;text-align:center;color:#fff;
  position:relative;overflow:hidden;
}
.report-hero::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse at 50% -10%,rgba(212,175,55,.18) 0%,transparent 60%),
    radial-gradient(ellipse at 80% 110%,rgba(0,206,201,.12) 0%,transparent 50%);
  pointer-events:none;
}
.report-hero::after{
  content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;
  background:repeating-linear-gradient(45deg,transparent,transparent 80px,rgba(255,255,255,.015) 80px,rgba(255,255,255,.015) 81px);
  pointer-events:none;
  animation:slideBg 60s linear infinite;
}
@keyframes slideBg{0%{transform:translate(0,0)}100%{transform:translate(80px,80px)}}

.hero-eyebrow{
  display:inline-block;
  border:1px solid rgba(212,175,55,.5);
  color:#f0c060;
  font-family:var(--font-sans);
  font-size:var(--fs-eyebrow);
  font-weight:600;letter-spacing:.18em;
  text-transform:uppercase;
  padding:6px 18px;border-radius:30px;
  margin-bottom:24px;position:relative;
  animation:pulseBadge 4s ease-in-out infinite;
}
@keyframes pulseBadge{
  0%,100%{box-shadow:0 0 0 0 rgba(212,175,55,.35)}
  50%{box-shadow:0 0 0 10px rgba(212,175,55,0)}
}
.hero-title{
  font-family:var(--font-serif);
  font-size:var(--fs-display);
  font-weight:700;
  line-height:1.18;
  letter-spacing:-.02em;
  color:#fff;
  margin-bottom:20px;
  position:relative;
  text-wrap:balance;
}
.hero-title span{display:block}
.hero-title .hl{color:#f0c060;font-style:italic;font-weight:600}
.hero-meta{
  font-family:var(--font-sans);
  font-size:var(--fs-small);
  color:rgba(255,255,255,.78);
  letter-spacing:.05em;margin-bottom:6px;position:relative;
}
.hero-method{font-family:var(--font-sans);font-size:13.5px;color:rgba(212,175,55,.95);margin-bottom:8px;position:relative;letter-spacing:.02em}
.hero-method strong{color:#f0c060;font-weight:600}
.hero-org{
  font-family:var(--font-sans);
  font-size:var(--fs-caption);
  color:rgba(255,255,255,.6);
  position:relative;letter-spacing:.04em;
}

/* ════════════════ Intro & Method card ════════════════ */
.intro-box{
  background:var(--bg-light);
  border-left:4px solid var(--accent-color);
  padding:18px 24px;
  font-family:var(--font-sans);
  font-size:var(--fs-lead);
  line-height:1.75;
  color:var(--text-dark);
  border-radius:0 8px 8px 0;
}

.method-card{
  background:linear-gradient(135deg,#eff6ff 0%,#f8fafc 100%);
  border:1.5px solid #bfdbfe;border-radius:12px;padding:20px 24px;
  display:grid;grid-template-columns:auto 1fr;gap:20px;align-items:flex-start;
  box-shadow:var(--shadow-soft);
  transition:transform .3s var(--transition),box-shadow .3s var(--transition);
}
:root[data-theme='dark'] .method-card{
  background:linear-gradient(135deg,#1e3a5f 0%,#1e293b 100%);
  border-color:#3b5680;
}
.method-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md)}
.method-icon{
  font-size:36px;background:#fff;border:1.5px solid #bfdbfe;border-radius:50%;
  width:64px;height:64px;display:flex;align-items:center;justify-content:center;
  box-shadow:var(--shadow-soft);
  animation:bobble 4s ease-in-out infinite;
}
:root[data-theme='dark'] .method-icon{background:#1e293b;border-color:#3b5680}
@keyframes bobble{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
.method-title{
  font-family:var(--font-serif);
  font-size:18px;font-weight:700;color:#1e40af;margin-bottom:8px;
  letter-spacing:-.01em;
}
:root[data-theme='dark'] .method-title{color:#93c5fd}
.method-desc{
  font-family:var(--font-sans);
  font-size:14.5px;color:var(--text-mid);line-height:1.75;margin-bottom:12px;
}
.method-meta{display:flex;flex-wrap:wrap;gap:8px}
.method-pill{
  display:inline-block;font-family:var(--font-sans);
  font-size:12.5px;font-weight:600;
  padding:5px 12px;border-radius:20px;
  background:#dbeafe;color:#1e40af;border:1px solid #bfdbfe;
  transition:transform .2s var(--transition);
}
:root[data-theme='dark'] .method-pill{background:#1e3a5f;color:#93c5fd;border-color:#3b5680}
.method-pill:hover{transform:scale(1.05)}

/* ════════════════ Quick nav ════════════════ */
.std-nav{display:flex;flex-wrap:wrap;gap:8px}
.std-nav a{
  text-decoration:none;color:#1e3a8a;
  font-family:var(--font-sans);
  font-size:13px;font-weight:600;letter-spacing:.02em;
  padding:7px 14px;border-radius:999px;
  border:1px solid #bfdbfe;background:#eff6ff;
  transition:.2s;
}
:root[data-theme='dark'] .std-nav a{background:#1e3a5f;color:#93c5fd;border-color:#3b5680}
.std-nav a:hover{background:#1e3a8a;color:#fff;border-color:#1e3a8a;transform:translateY(-1px)}

/* ════════════════ Section headings ════════════════ */
.section-eyebrow{
  display:flex;align-items:center;gap:10px;
  font-family:var(--font-sans);
  font-size:var(--fs-eyebrow);
  font-weight:700;letter-spacing:.18em;
  color:#1e40af;text-transform:uppercase;margin-bottom:8px;
}
:root[data-theme='dark'] .section-eyebrow{color:#93c5fd}
.section-eyebrow::before{
  content:'';display:inline-block;width:32px;height:3px;
  background:#1e40af;border-radius:2px;flex-shrink:0;
}
:root[data-theme='dark'] .section-eyebrow::before{background:#93c5fd}
.section-heading{
  font-family:var(--font-serif);
  font-size:var(--fs-h1);font-weight:700;
  color:var(--primary-color);margin-bottom:6px;
  letter-spacing:-.02em;
}
:root[data-theme='dark'] .section-heading{color:#f0c060}
.section-sub{
  font-family:var(--font-sans);
  font-size:var(--fs-small);color:var(--text-muted);margin-bottom:16px;
}

/* ════════════════ TomTom ════════════════ */
.tomtom-card{
  border:1.5px solid #fecaca;border-radius:12px;padding:18px 20px;
  display:flex;gap:18px;align-items:flex-start;
  background:linear-gradient(145deg,#fff7f7,#fff);
  box-shadow:var(--shadow-soft);
}
:root[data-theme='dark'] .tomtom-card{background:linear-gradient(145deg,#3f1d1d,#1e293b);border-color:#7f1d1d}
.tomtom-brand{
  background:#df1b12;color:#fff;
  font-family:var(--font-sans);
  font-size:11px;font-weight:900;line-height:1.3;
  padding:10px 8px;border-radius:8px;text-align:center;
  letter-spacing:.06em;min-width:54px;flex-shrink:0;
  box-shadow:0 2px 6px rgba(223,27,18,.3);
}
.tomtom-body{flex:1;min-width:0}
.tomtom-city{
  font-family:var(--font-serif);
  font-size:15px;font-weight:700;color:#b91c1c;margin-bottom:12px;
}
:root[data-theme='dark'] .tomtom-city{color:#f87171}
.tomtom-stats-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:8px}
.tomtom-stat{
  border:1px solid #fecaca;border-radius:8px;padding:10px;
  background:#fff;text-align:center;
  transition:transform .2s var(--transition);
}
:root[data-theme='dark'] .tomtom-stat{background:#1e293b;border-color:#7f1d1d}
.tomtom-stat:hover{transform:translateY(-2px);box-shadow:var(--shadow-soft)}
.tomtom-value{
  font-family:var(--font-mono);
  color:#b91c1c;font-size:20px;font-weight:700;line-height:1.15;
  font-variant-numeric:tabular-nums;
}
:root[data-theme='dark'] .tomtom-value{color:#f87171}
.tomtom-label{
  font-family:var(--font-sans);
  color:var(--text-muted);font-size:11.5px;margin-top:3px;line-height:1.4;
}
.tomtom-sub-label{font-family:var(--font-sans);color:#94a3b8;font-size:11px;margin-top:2px}
.tomtom-stats-row2{display:flex;gap:8px}
.tomtom-stats-row2 .tomtom-stat{flex:1}
.tomtom-note{
  margin-top:12px;color:#7f1d1d;font-size:13px;line-height:1.7;
  background:#fff5f5;border-radius:6px;padding:10px 12px;
  font-family:var(--font-sans);
}
:root[data-theme='dark'] .tomtom-note{background:#3f1d1d;color:#fca5a5}

/* ════════════════ Compare table ════════════════ */
.compare-card{
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  overflow:hidden;box-shadow:var(--shadow-soft);
}
.compare-title{
  padding:14px 18px;
  font-family:var(--font-serif);
  font-size:16px;font-weight:700;color:var(--primary-color);
  background:var(--surface-3);border-bottom:1px solid var(--border);
  letter-spacing:-.01em;
}
:root[data-theme='dark'] .compare-title{color:#f0c060;background:#293548}
.ctable-wrap{overflow-x:auto}
.compare-table{width:100%;border-collapse:collapse;font-size:13.5px;min-width:560px}
.compare-table th,.compare-table td{
  border-right:1px solid var(--border);
  border-bottom:1px solid var(--border);
  padding:11px 12px;text-align:center;vertical-align:middle;
}
.compare-table th:last-child,.compare-table td:last-child{border-right:none}
.compare-table tr:last-child td{border-bottom:none}
.compare-table tbody tr{transition:background .2s}
.compare-table tbody tr:hover{background:var(--surface-2)}
.compare-table th{
  background:var(--surface-2);color:var(--text-muted);
  font-family:var(--font-sans);
  font-size:12.5px;font-weight:700;
  letter-spacing:.02em;
}
.compare-table th small{font-weight:400;color:var(--text-muted)}
.compare-table td:first-child,.compare-table th:first-child{text-align:left}
.chip{
  display:inline-block;
  font-family:var(--font-mono);
  font-size:13px;font-weight:700;
  padding:4px 11px;border-radius:20px;white-space:nowrap;
  font-variant-numeric:tabular-nums;
  transition:transform .2s;
}
.chip:hover{transform:scale(1.05)}
.cr{background:#fef2f2;color:#b91c1c;border:1px solid #fecaca}
.cb{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}
.cg{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0}
:root[data-theme='dark'] .cr{background:#3f1d1d;color:#fca5a5;border-color:#7f1d1d}
:root[data-theme='dark'] .cb{background:#1e3a5f;color:#93c5fd;border-color:#3b5680}
:root[data-theme='dark'] .cg{background:#14532d;color:#86efac;border-color:#15803d}
.cn{color:var(--text-muted);font-size:13px}
.row-label{font-weight:700;color:var(--text-dark);font-family:var(--font-sans);font-size:13.5px}
.row-sub{font-size:12px;color:var(--text-muted);font-family:var(--font-sans)}

.source-note{
  background:var(--surface-2);border:1px solid var(--border);border-radius:10px;
  padding:14px 18px;font-family:var(--font-sans);
  font-size:13px;color:var(--text-mid);line-height:1.75;
}
.source-note strong{color:var(--text-dark)}

/* ════════════════ Zone-district ════════════════ */
.zone-district-card{
  background:linear-gradient(135deg,var(--surface) 0%,#f8fbff 100%);
  border:2px solid #bfdbfe;border-radius:10px;padding:16px;
  box-shadow:var(--shadow-soft);
}
:root[data-theme='dark'] .zone-district-card{
  background:linear-gradient(135deg,#1e293b,#0f172a);border-color:#3b5680;
}
.zone-district-header{
  display:flex;align-items:center;justify-content:space-between;
  gap:10px;flex-wrap:wrap;border-bottom:1px solid var(--border);
  padding-bottom:12px;margin-bottom:14px;
}
.zone-district-header h2{
  font-family:var(--font-serif);
  font-size:16px;font-weight:700;color:#1e3a8a;margin:0;
}
:root[data-theme='dark'] .zone-district-header h2{color:#93c5fd}
.zd-badge{
  font-family:var(--font-sans);
  font-size:12px;font-weight:700;color:#1e40af;background:#dbeafe;
  border:1px solid #93c5fd;border-radius:20px;padding:3px 10px;
  letter-spacing:.04em;
}
:root[data-theme='dark'] .zd-badge{background:#1e3a5f;color:#93c5fd;border-color:#3b5680}
.zone-district-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.zd-item{
  border-radius:8px;padding:12px;border-left:4px solid transparent;
  transition:transform .2s,box-shadow .2s;
}
.zd-item:hover{transform:translateY(-2px);box-shadow:var(--shadow-soft)}
.zd-item.inner{background:#fff5f5;border-left-color:#d63031}
.zd-item.middle{background:#fff7ed;border-left-color:#e17055}
.zd-item.outer{background:#f0fdf4;border-left-color:#00b894}
:root[data-theme='dark'] .zd-item.inner{background:#3f1d1d}
:root[data-theme='dark'] .zd-item.middle{background:#3a2310}
:root[data-theme='dark'] .zd-item.outer{background:#14532d}
.zd-title{
  font-family:var(--font-serif);
  font-size:15px;font-weight:700;margin-bottom:6px;letter-spacing:-.01em;
}
.zd-title.inner{color:#b91c1c}
.zd-title.middle{color:#c2410c}
.zd-title.outer{color:#166534}
:root[data-theme='dark'] .zd-title.inner{color:#fca5a5}
:root[data-theme='dark'] .zd-title.middle{color:#fdba74}
:root[data-theme='dark'] .zd-title.outer{color:#86efac}
.zd-count{
  display:inline-block;margin-left:6px;
  font-family:var(--font-sans);
  font-size:11px;font-weight:700;border-radius:10px;padding:2px 8px;
}
.zd-count.inner{background:#fef2f2;color:#b91c1c}
.zd-count.middle{background:#fff7ed;color:#c2410c}
.zd-count.outer{background:#f0fdf4;color:#166534}
.zd-desc{font-family:var(--font-sans);font-size:12.5px;color:var(--text-muted);margin-bottom:7px}
.zd-districts{font-family:var(--font-sans);font-size:12.5px;color:var(--text-mid);line-height:1.75}

/* ════════════════ Control panel ════════════════ */
.control-panel{
  background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:14px;
  display:grid;grid-template-columns:1.1fr 1fr 1.3fr auto auto;gap:10px;align-items:end;
}
.control-group{display:flex;flex-direction:column;gap:5px}
.control-label{
  font-family:var(--font-sans);
  font-size:13px;color:var(--text-muted);font-weight:600;
  letter-spacing:.02em;
}
.control-input,.control-select,.control-btn{
  height:40px;border-radius:8px;border:1px solid var(--border-strong);
  font-family:var(--font-sans);font-size:14px;padding:0 12px;
  background:var(--surface);color:var(--text-dark);
}
.control-select{cursor:pointer}
.control-input:focus,.control-select:focus{
  outline:none;border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.2);
}
.control-btn{cursor:pointer;font-weight:600;transition:.2s;letter-spacing:.02em}
.control-btn:hover{background:var(--surface-3);transform:translateY(-1px)}
.control-btn.primary{background:var(--primary-color);border-color:var(--primary-color);color:#fff}
.control-btn.primary:hover{background:#0d3a73}
.filter-status{font-family:var(--font-sans);font-size:13px;color:var(--text-muted);margin-top:10px}
.is-hidden{display:none !important}

/* ════════════════ KPI cards ════════════════ */
.cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.data-card{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:22px;
  position:relative;box-shadow:var(--shadow-soft);
  transition:transform .3s var(--transition),box-shadow .3s var(--transition);
  overflow:hidden;
}
.data-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg)}
.data-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:6px;
  border-radius:12px 12px 0 0;
}
.card-inner::before{background:linear-gradient(90deg,var(--inner-color) 0%,#ff7675 100%)}
.card-middle::before{background:linear-gradient(90deg,var(--middle-color) 0%,#fab1a0 100%)}
.card-outer::before{background:linear-gradient(90deg,var(--outer-color) 0%,#55efc4 100%)}
.data-card::after{
  content:'';position:absolute;top:-10px;right:-10px;width:80px;height:80px;
  border-radius:50%;opacity:.04;pointer-events:none;
}
.card-inner::after{background:var(--inner-color)}
.card-middle::after{background:var(--middle-color)}
.card-outer::after{background:var(--outer-color)}
.card-title{
  font-family:var(--font-serif);
  font-size:17px;font-weight:700;margin-bottom:6px;text-align:center;
  position:relative;letter-spacing:-.01em;
}
.card-year-badge{
  font-family:var(--font-sans);
  font-size:11px;color:var(--text-muted);text-align:center;margin-bottom:14px;
  letter-spacing:.04em;
}
.card-direction-section{margin-top:6px;position:relative}
.card-direction-label{
  font-family:var(--font-sans);
  font-size:12.5px;font-weight:600;margin-bottom:5px;
  display:flex;align-items:center;gap:4px;letter-spacing:.04em;
}
.card-dir-in{color:#2563eb}
.card-dir-out{color:#7c3aed}
:root[data-theme='dark'] .card-dir-in{color:#93c5fd}
:root[data-theme='dark'] .card-dir-out{color:#c4b5fd}
.card-value{
  font-family:var(--font-mono);
  font-size:26px;font-weight:700;text-align:center;margin-bottom:10px;
  font-variant-numeric:tabular-nums;
  letter-spacing:-.02em;
}
.card-unit{font-family:var(--font-sans);font-size:14px;font-weight:400;color:var(--text-muted)}
.card-inner .card-value .kpi-speed{color:var(--inner-color)}
.card-middle .card-value .kpi-speed{color:var(--middle-color)}
.card-outer .card-value .kpi-speed{color:var(--outer-color)}
.card-stats{
  font-family:var(--font-sans);
  font-size:12.5px;display:flex;justify-content:space-between;gap:8px;
  color:var(--text-muted);padding:4px 0;
}
.card-stats span:last-child{
  font-family:var(--font-mono);
  font-weight:700;color:var(--text-dark);font-variant-numeric:tabular-nums;
}
.card-divider{border:none;border-top:2px solid var(--border);margin:12px 0}

/* ════════════════ Line chart ════════════════ */
.line-card{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-md);
  box-shadow:var(--shadow-soft);padding:16px 18px;
}
.line-toolbar{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;margin-bottom:12px}
.line-title{
  font-family:var(--font-serif);
  font-size:17px;font-weight:700;color:var(--primary-color);margin-bottom:5px;
  letter-spacing:-.01em;
}
:root[data-theme='dark'] .line-title{color:#f0c060}
.line-sub{font-family:var(--font-sans);font-size:13px;color:var(--text-muted)}
.dir-toggle{display:flex;background:var(--surface-3);border-radius:10px;padding:3px;border:1px solid var(--border)}
.dir-btn{
  background:transparent;border:none;padding:7px 16px;
  font-family:var(--font-sans);font-size:13px;font-weight:600;color:var(--text-muted);
  border-radius:8px;cursor:pointer;transition:.2s;
}
.dir-btn.active{background:var(--surface);color:var(--primary-color);box-shadow:0 1px 3px rgba(0,0,0,.06)}
.dir-btn:hover:not(.active){color:var(--primary-color)}
.line-wrap{overflow-x:auto}
.line-wrap svg{display:block;width:100%;min-width:680px;max-width:100%;height:auto}
.line-legend{display:flex;gap:14px;flex-wrap:wrap;font-size:13px;color:var(--text-mid);margin-top:10px;font-family:var(--font-sans)}
.legend-item{display:inline-flex;align-items:center;gap:6px}
.legend-dot{width:10px;height:10px;border-radius:50%;display:inline-block}
.line-hit{cursor:crosshair}

/* ════════════════ Section title (lower sections) ════════════════ */
.section-title{
  font-family:var(--font-serif);
  font-size:var(--fs-h2);font-weight:700;color:var(--primary-color);
  margin-bottom:8px;display:flex;align-items:center;gap:10px;
  letter-spacing:-.01em;
}
:root[data-theme='dark'] .section-title{color:#f0c060}
.section-title::before{content:'';display:inline-block;width:5px;height:20px;background:var(--accent-color);border-radius:2px}
.rt-intro{font-family:var(--font-sans);font-size:13.5px;color:var(--text-muted);margin-bottom:16px;line-height:1.7}
.rt-icon-hint{
  display:inline-block;background:#1e40af;color:#fff;
  padding:1px 7px;border-radius:4px;font-size:11px;margin:0 2px;
}

/* ════════════════ Road Table Toolbar ════════════════ */
.rt-toolbar{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:14px;align-items:center}
#rtSearch{flex:1;min-width:240px;max-width:400px}

/* ════════════════ Zone Accordion ════════════════ */
.zone-accordion{display:flex;flex-direction:column;gap:14px}
.zone-acc{
  border:1.5px solid var(--border);border-radius:var(--radius-lg);
  overflow:hidden;background:var(--surface);
  box-shadow:var(--shadow-soft);
  transition:box-shadow .3s var(--transition);
}
.zone-acc:hover{box-shadow:var(--shadow-md)}
.zone-acc[open]{box-shadow:var(--shadow-md)}
.zone-acc.inner{border-left:6px solid var(--inner-color)}
.zone-acc.middle{border-left:6px solid var(--middle-color)}
.zone-acc.outer{border-left:6px solid var(--outer-color)}
.zone-acc[open].inner{background:linear-gradient(135deg,var(--surface) 0%,#fff5f5 100%)}
.zone-acc[open].middle{background:linear-gradient(135deg,var(--surface) 0%,#fff7ed 100%)}
.zone-acc[open].outer{background:linear-gradient(135deg,var(--surface) 0%,#f0fdf4 100%)}
:root[data-theme='dark'] .zone-acc[open].inner{background:linear-gradient(135deg,#1e293b 0%,#3f1d1d 100%)}
:root[data-theme='dark'] .zone-acc[open].middle{background:linear-gradient(135deg,#1e293b 0%,#3a2310 100%)}
:root[data-theme='dark'] .zone-acc[open].outer{background:linear-gradient(135deg,#1e293b 0%,#14532d 100%)}

.zone-summary{
  cursor:pointer;list-style:none;padding:18px 22px;
  display:flex;justify-content:space-between;align-items:center;gap:14px;
  user-select:none;flex-wrap:wrap;
  transition:background .2s;
}
.zone-summary::-webkit-details-marker{display:none}
.zone-summary::marker{display:none}
.zone-summary:hover{background:rgba(0,0,0,.02)}
.zone-summary-left{display:flex;align-items:center;gap:14px;flex:1;min-width:0}
.zone-icon{
  font-size:30px;width:52px;height:52px;
  display:flex;align-items:center;justify-content:center;
  background:var(--surface);border-radius:14px;flex-shrink:0;
  box-shadow:var(--shadow-soft);border:1px solid var(--border);
  transition:transform .3s var(--transition);
}
.zone-acc:hover .zone-icon{transform:scale(1.08) rotate(-3deg)}
.zone-summary-text{min-width:0}
.zone-summary-title{
  font-family:var(--font-serif);
  font-size:18px;font-weight:700;color:var(--primary-color);
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  letter-spacing:-.01em;
}
.zone-acc.inner .zone-summary-title{color:var(--inner-color)}
.zone-acc.middle .zone-summary-title{color:var(--middle-color)}
.zone-acc.outer .zone-summary-title{color:var(--outer-color)}
.zone-summary-count{
  display:inline-block;
  font-family:var(--font-sans);font-size:12px;font-weight:700;
  padding:3px 11px;border-radius:20px;
  background:rgba(0,0,0,.05);color:var(--text-dark);
  letter-spacing:.04em;
}
:root[data-theme='dark'] .zone-summary-count{background:rgba(255,255,255,.1);color:var(--text-dark)}
.zone-summary-meta{font-family:var(--font-sans);font-size:13px;color:var(--text-muted);margin-top:4px}
.zone-summary-meta strong{
  color:var(--text-dark);font-family:var(--font-mono);font-variant-numeric:tabular-nums;font-weight:700;
}
.zone-summary-right{display:flex;align-items:center;gap:14px;flex-shrink:0}
.zone-stat-mini{
  display:grid;grid-template-columns:repeat(2,auto);gap:5px 12px;
  padding:9px 14px;background:var(--surface-2);border-radius:8px;border:1px solid var(--border);
}
.zsm-row{display:flex;align-items:center;gap:6px;font-family:var(--font-sans);font-size:11.5px}
.zsm-dot{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0}
.zsm-dot.am-in{background:#d63031}
.zsm-dot.am-out{background:#e17055}
.zsm-dot.pm-in{background:#6c5ce7}
.zsm-dot.pm-out{background:#0984e3}
.zsm-val{font-family:var(--font-mono);font-weight:700;color:var(--text-dark);font-variant-numeric:tabular-nums}
.zone-chevron{
  font-size:14px;color:var(--text-muted);
  transition:transform .3s var(--transition);
  display:inline-block;width:20px;text-align:center;
}
.zone-acc[open] .zone-chevron{transform:rotate(180deg);color:var(--primary-color)}
.zone-acc-body{padding:0 22px 22px;animation:slideDown .35s var(--transition)}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}

/* ════════════════ Road Table ════════════════ */
.rt-wrap{
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  overflow-x:auto;box-shadow:var(--shadow-soft);
}
.rt-table{width:100%;min-width:800px;border-collapse:collapse}
.rt-table thead th{
  padding:11px 8px;background:var(--surface-3);
  font-family:var(--font-sans);font-size:11.5px;font-weight:700;color:var(--text-muted);
  text-transform:uppercase;letter-spacing:.08em;
  border-bottom:2px solid var(--border-strong);border-right:1px solid var(--border);
  white-space:nowrap;user-select:none;
}
.rt-table thead th.th-left{text-align:left}
.rt-table thead th small{display:block;font-weight:400;text-transform:none;margin-top:2px;letter-spacing:0}
.rt-table thead th.sortable{cursor:pointer;transition:.2s}
.rt-table thead th.sortable:hover{background:var(--border);color:var(--primary-color)}
.rt-table thead th.sortable::after{content:'⇅';opacity:.35;margin-left:4px;font-size:10px}
.rt-table thead th.sort-asc::after{content:'▲';opacity:1;color:#1d4ed8}
.rt-table thead th.sort-desc::after{content:'▼';opacity:1;color:#1d4ed8}
.rt-table thead th.th-group{text-align:center;color:#fff;padding:9px}
.rt-table thead th.th-group.am{background:linear-gradient(135deg,#e17055,#d63031)}
.rt-table thead th.th-group.pm{background:linear-gradient(135deg,#6c5ce7,#0984e3)}
.rt-table tbody td{
  padding:9px 8px;font-family:var(--font-sans);font-size:13.5px;color:var(--text-dark);
  border-bottom:1px solid var(--border);border-right:1px solid var(--border);
  text-align:center;vertical-align:middle;
}
.rt-table tbody td.td-left{text-align:left}
.rt-table tbody td.td-num{font-family:var(--font-mono);font-variant-numeric:tabular-nums;font-weight:600}
.rt-table tbody tr{transition:background .15s,transform .15s}
.rt-table tbody tr:nth-child(even){background:var(--surface-2)}
.rt-table tbody tr:hover{background:#eff6ff}
:root[data-theme='dark'] .rt-table tbody tr:hover{background:#1e3a5f}
.rt-table .rd-name{font-family:var(--font-serif);font-weight:700;color:var(--primary-color);display:block;font-size:14px}
:root[data-theme='dark'] .rt-table .rd-name{color:#f0c060}
.rt-table .rd-seg{font-family:var(--font-sans);font-size:11.5px;color:var(--text-muted);display:block;margin-top:2px}

.rt-table .speed-cell{
  font-family:var(--font-mono);
  font-weight:700;padding:4px 8px;border-radius:6px;
  display:inline-flex;align-items:center;gap:4px;
  min-width:56px;font-variant-numeric:tabular-nums;
  position:relative;transition:transform .15s;
}
.rt-table .speed-cell:hover{transform:scale(1.08)}
.rt-table .speed-cell .se{font-size:9px;opacity:.9}
.rt-table .speed-cell.fast{background:linear-gradient(135deg,#bbf7d0 0%,#86efac 100%);color:#065f46}
.rt-table .speed-cell.mid{background:linear-gradient(135deg,#bfdbfe 0%,#93c5fd 100%);color:#1e3a8a}
.rt-table .speed-cell.slow{background:linear-gradient(135deg,#fde68a 0%,#fcd34d 100%);color:#78350f}
.rt-table .speed-cell.jam{
  background:linear-gradient(135deg,#fecaca 0%,#fca5a5 100%);color:#7f1d1d;
  animation:jamPulse 2s ease-in-out infinite;
}
@keyframes jamPulse{
  0%,100%{box-shadow:0 0 0 0 rgba(220,38,38,.3)}
  50%{box-shadow:0 0 0 4px rgba(220,38,38,0)}
}
.rt-table .speed-cell.na{
  background:transparent;color:var(--text-muted);font-weight:500;font-size:10.5px;
  padding:2px 4px;font-style:italic;font-family:var(--font-sans);
}
.mini-chart{display:inline-block;width:88px;height:32px;vertical-align:middle}
.mini-chart .mc-bar{transition:opacity .2s}
.mini-chart:hover .mc-bar{opacity:.85}

.rt-legend-bottom{
  display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;padding:12px 16px;
  background:var(--surface-2);border:1px solid var(--border);border-radius:10px;
  font-family:var(--font-sans);font-size:12.5px;color:var(--text-muted);align-items:center;
}
.lg-section{font-weight:700;color:var(--text-dark)}
.lg-item{display:inline-flex;align-items:center;gap:5px}
.lg{display:inline-block;width:14px;height:14px;border-radius:4px;vertical-align:middle;margin-right:2px}
.lg-fast{background:linear-gradient(135deg,#bbf7d0,#86efac);border:1px solid #6ee7b7}
.lg-mid{background:linear-gradient(135deg,#bfdbfe,#93c5fd);border:1px solid #93c5fd}
.lg-slow{background:linear-gradient(135deg,#fde68a,#fcd34d);border:1px solid #fcd34d}
.lg-jam{background:linear-gradient(135deg,#fecaca,#fca5a5);border:1px solid #fca5a5}

/* ════════════════ Scenario / BAU ════════════════ */
.scenario-card{
  border:1px solid #f5c2c7;background:linear-gradient(145deg,#fff7f8,#fff0f2);
  border-radius:10px;padding:16px 18px;box-shadow:var(--shadow-soft);
}
:root[data-theme='dark'] .scenario-card{background:linear-gradient(145deg,#3f1d1d,#1e293b);border-color:#7f1d1d}
.scenario-title{
  font-family:var(--font-serif);
  font-size:17px;font-weight:700;color:#8e1b2a;margin-bottom:5px;letter-spacing:-.01em;
}
:root[data-theme='dark'] .scenario-title{color:#f87171}
.scenario-sub{font-family:var(--font-sans);font-size:14px;color:var(--text-muted);margin-bottom:14px}
.scenario-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
.scenario-item{
  border:1px solid #f1d0d5;border-radius:8px;background:var(--surface);padding:12px;
  transition:transform .2s,box-shadow .2s;
}
:root[data-theme='dark'] .scenario-item{background:#1e293b;border-color:#7f1d1d}
.scenario-item:hover{transform:translateY(-2px);box-shadow:var(--shadow-soft)}
.scenario-zone{
  font-family:var(--font-serif);
  font-size:14px;font-weight:700;margin-bottom:8px;letter-spacing:-.01em;
}
.scenario-item[data-zone='inner']  .scenario-zone{color:#d63031}
.scenario-item[data-zone='middle'] .scenario-zone{color:#e17055}
.scenario-item[data-zone='outer']  .scenario-zone{color:#00b894}
.scenario-kpi{font-family:var(--font-sans);font-size:13.5px;color:var(--text-mid);margin-bottom:5px}
.scenario-kpi strong{font-family:var(--font-mono);font-variant-numeric:tabular-nums;color:var(--text-dark);font-weight:700}
.scenario-note{margin-top:12px;font-family:var(--font-sans);font-size:13px;color:#7c2d12;line-height:1.7}
:root[data-theme='dark'] .scenario-note{color:#fdba74}

/* ════════════════ Modern table ════════════════ */
.modern-table{width:100%;border-collapse:collapse;font-size:15px;font-family:var(--font-sans)}
.modern-table th{
  background:var(--primary-color);color:#fff;font-weight:600;
  padding:13px;text-align:center;letter-spacing:.04em;font-size:14px;
}
.modern-table td{padding:13px;text-align:center;border-bottom:1px solid var(--border)}
.modern-table tr:last-child td{border-bottom:2px solid var(--primary-color)}
.modern-table tr:nth-child(even){background:var(--surface-2)}
.modern-table tbody tr{transition:background .2s}
.modern-table tbody tr:hover{background:#fef3c7}
:root[data-theme='dark'] .modern-table tbody tr:hover{background:#3a2310}
.text-trend-down{color:var(--status-red);font-weight:600;font-family:var(--font-mono)}
.text-trend-up{color:var(--status-green);font-weight:600;font-family:var(--font-mono)}

/* ════════════════ Bottom grid ════════════════ */
.bottom-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px}
.insight-list,.policy-list{list-style:none}
.insight-list li{
  position:relative;padding-left:22px;margin-bottom:11px;
  font-family:var(--font-sans);font-size:15px;line-height:1.7;
}
.insight-list li::before{
  content:'•';position:absolute;left:0;color:var(--status-orange);
  font-weight:bold;font-size:20px;line-height:1.4;
}
.policy-list li{
  background:var(--surface-2);border:1px solid var(--border);
  padding:11px 16px;margin-bottom:9px;border-radius:6px;
  font-family:var(--font-sans);font-size:15px;
  display:flex;align-items:center;gap:10px;line-height:1.65;
  transition:transform .2s,background .2s;
}
.policy-list li:hover{transform:translateX(4px);background:#dbeafe}
:root[data-theme='dark'] .policy-list li:hover{background:#1e3a5f}
.policy-list li::before{content:'✓';color:var(--status-green);font-weight:bold;flex-shrink:0}

/* ════════════════ Footer ════════════════ */
.footer{
  margin-top:auto;padding:22px 50px 0;border-top:1px solid var(--border);
  display:flex;justify-content:space-between;gap:16px;
  font-family:var(--font-sans);font-size:14px;color:var(--text-muted);flex-wrap:wrap;
}
.footer strong{color:var(--primary-color)}
:root[data-theme='dark'] .footer strong{color:#f0c060}
.footer-right{text-align:right}
.footer-right a{font-size:12.5px;color:#1e40af;text-decoration:none;letter-spacing:.04em}
.footer-right a:hover{text-decoration:underline}

/* ════════════════ Back to top ════════════════ */
.to-top{
  position:fixed;bottom:24px;right:24px;
  width:48px;height:48px;border-radius:50%;
  border:none;background:var(--primary-color);color:#fff;
  font-size:22px;cursor:pointer;
  box-shadow:var(--shadow-lg);
  opacity:0;pointer-events:none;
  transition:opacity .2s,transform .2s;z-index:999;
}
.to-top.visible{opacity:1;pointer-events:auto}
.to-top:hover{transform:translateY(-3px);background:#0d3a73}

/* ═══════════════════════════════════════════════════════════════
   PC ≥ 1200px (default scale already applied via :root)
   ═══════════════════════════════════════════════════════════════ */
@media (min-width:1200px){
  .a4-canvas{width:min(1320px,100%);min-height:auto;padding:0 0 50px}
  .a4-body{padding:0 60px}
  .footer{padding:24px 60px 0}
}

/* ═══════════════════════════════════════════════════════════════
   Tablet 768–1199px
   ═══════════════════════════════════════════════════════════════ */
@media (min-width:768px) and (max-width:1199px){
  :root{
    --fs-display:30px;
    --fs-h1:22px;
    --fs-h2:19px;
    --fs-h3:16px;
    --fs-lead:16px;
    --fs-body:15px;
    --fs-small:13.5px;
    --fs-caption:12px;
    --fs-eyebrow:11px;
  }
  body{padding:1rem}
  .a4-canvas{width:100%;min-height:auto;max-width:100%;padding:0 0 30px}
  .a4-body{padding:0 24px}
  .report-hero{padding:36px 28px 32px}
  .footer{padding:22px 24px 0}
  .cards-grid,.zone-district-grid,.bottom-grid,.scenario-grid{grid-template-columns:1fr 1fr}
  .control-panel{grid-template-columns:1fr 1fr}
  .control-panel button{grid-column:span 1}
  .tomtom-stats-grid{grid-template-columns:repeat(3,1fr)}
  .zone-summary-right{flex-wrap:wrap}
}

/* ═══════════════════════════════════════════════════════════════
   Mobile ≤ 767px
   ═══════════════════════════════════════════════════════════════ */
@media (max-width:767px){
  :root{
    --fs-display:22px;
    --fs-h1:18px;
    --fs-h2:16px;
    --fs-h3:14.5px;
    --fs-lead:15px;
    --fs-body:14.5px;
    --fs-small:13px;
    --fs-caption:11.5px;
    --fs-eyebrow:10.5px;
  }
  html{font-size:15px}
  body{padding:0}
  .utility-bar{font-size:12px}
  .utility-inner{padding:7px 12px;gap:8px}
  .utility-left{flex-direction:column;align-items:flex-start;gap:0;line-height:1.35}
  .util-sep{display:none}
  .a4-canvas{
    width:100%;min-height:auto;max-width:100%;padding:0 0 20px;
    border-radius:0;box-shadow:0 4px 14px rgba(0,0,0,.08);margin-bottom:0;
  }
  .report-hero{padding:28px 16px 24px}
  .a4-body{padding:0 16px;gap:20px}
  .footer{padding:18px 16px 0;flex-direction:column;align-items:flex-start}
  .footer-right{text-align:left}
  .control-panel{grid-template-columns:1fr;gap:8px}
  .tomtom-stats-grid,
  .cards-grid,
  .zone-district-grid,
  .bottom-grid,
  .scenario-grid{grid-template-columns:1fr}
  .tomtom-card{flex-direction:column}
  .method-card{grid-template-columns:1fr;text-align:center}
  .method-icon{margin:0 auto}
  .method-meta{justify-content:center}
  .compare-table,.modern-table{font-size:12.5px}
  .compare-table,.modern-table{display:block;overflow-x:auto;white-space:nowrap}
  .rt-toolbar{flex-direction:column;align-items:stretch}
  #rtSearch{max-width:none}
  .line-toolbar{flex-direction:column;align-items:stretch}
  .to-top{bottom:14px;right:14px;width:42px;height:42px;font-size:19px}

  /* Accordion mobile */
  .zone-summary{padding:14px 16px}
  .zone-summary-right{width:100%;justify-content:space-between;margin-top:10px}
  .zone-icon{width:44px;height:44px;font-size:24px}
  .zone-summary-title{font-size:15.5px}
  .zone-summary-meta{font-size:12px}
  .zone-stat-mini{padding:6px 10px;grid-template-columns:repeat(4,auto);gap:8px}
  .zsm-val{font-size:11px}
  .zone-acc-body{padding:0 12px 16px}
  .mini-chart{width:64px;height:26px}
}

/* ════════════════ Print ════════════════ */
@media print{
  body{background:#fff;padding:0}
  .a4-canvas{box-shadow:none;width:100%;padding:0;margin:0}
  .report-hero{
    background:#0b2545 !important;
    -webkit-print-color-adjust:exact;print-color-adjust:exact;
  }
  .utility-bar,.to-top,.control-panel,.dir-toggle,.rt-toolbar,.std-nav,.skip-link{display:none !important}
  .zone-acc{break-inside:avoid;page-break-inside:avoid;box-shadow:none;border:1px solid #ccc}
  details[open] .zone-acc-body,details:not([open]) .zone-acc-body{display:block !important}
  details:not([open]) summary{display:none}
  section,.line-card,.compare-card,.scenario-card,.method-card{break-inside:avoid}
}
